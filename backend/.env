# TiDB Database (MySQL compatible)
DB_HOST=gateway01.ap-southeast-1.prod.aws.tidbcloud.com
DB_PORT=4000
DB_USER=seu-usuario.root
DB_PASSWORD=sua-senha-aqui
DB_NAME=academic_binder

# SSL/TLS for TiDB Serverless (MANDATORY)
TIDB_ENABLE_SSL=true

# OpenAI
OPENAI_API_KEY=sk-your-key-here

# Amazon Web Services (Polly)
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_REGION=us-east-1
POLLY_VOICE_ID=Camila
POLLY_ENGINE=neural

# PPDRIVE (free self-hosted storage)
PPDRIVE_URL=http://localhost:8080
PPDRIVE_API_KEY=
PPDRIVE_BUCKET_PREFIX=academic

# JWT for local authentication
JWT_SECRET=your_jwt_secret_key_here_make_it_long_and_random

# Frontend URL (for redirects)
FRONTEND_URL=http://localhost:3001

# Server
PORT=3000
