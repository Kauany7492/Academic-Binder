# Database
DB_HOST=db
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=academic_binder
DB_PORT=5432

# OpenAI (para transcrições e sumarização)
OPENAI_API_KEY=sk-your-key-here

# Amazon Web Services (Polly)
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_REGION=us-east-1
POLLY_VOICE_ID=Camila
POLLY_ENGINE=neural

# Tesseract OCR (offline) - não precisa de credenciais

# PPDRIVE (armazenamento gratuito auto-hospedado)
PPDRIVE_URL=http://localhost:8080
PPDRIVE_API_KEY=                     # Opcional, se habilitar autenticação no PPDRIVE
PPDRIVE_BUCKET_PREFIX=academic_binder # Prefixo para os buckets

# JWT for local authentication
JWT_SECRET=your_jwt_secret_key

# Frontend URL (for OAuth redirect)
FRONTEND_URL=http://localhost:3001

# Server
PORT=3000
